<!DOCTYPE html>
<html>
<head>
<meta charset="[CharSet]">
<link rel="icon" href="favicon.ico">
<link rel="stylesheet" href="sprites.css">
<title>[eMuleAppName] [version] - [WebControl]</title>
<style>
body {
  margin: 0; padding: 0;
  font-family: Tahoma, Verdana, Arial, sans-serif;
  font-size: 9pt;
  background-color: #005784;
  color: #fff;
}
.login-wrap {
  display: flex; align-items: center; justify-content: center;
  min-height: 100vh;
}
.login-box {
  background: #003C6E;
  border: 1px solid #002244;
  border-radius: 4px;
  padding: 30px 40px;
  text-align: center;
  min-width: 320px;
}
.login-box .logo { margin-bottom: 16px; }
.login-box h2 { margin: 0 0 4px; font-size: 14pt; }
.login-box .version { font-size: 8pt; color: #99CCFF; margin-bottom: 20px; }
.login-box input[type="password"] {
  width: 200px; padding: 6px 8px;
  border: 1px solid #002244; border-radius: 3px;
  background: #1F76A5; color: #fff; font-size: 10pt;
}
.login-box input[type="password"]:focus { outline: 1px solid #FFC412; }
.login-box input[type="submit"] {
  margin-top: 12px; padding: 6px 24px;
  border: 1px solid #002244; border-radius: 3px;
  background: #0075B3; color: #fff; font-size: 9pt; cursor: pointer;
}
.login-box input[type="submit"]:hover { background: #1F76A5; }
.failed { font-weight: bold; color: #FF0000; margin-top: 10px; }
form { display: inline; }
</style>
</head>
<body>
<div class="login-wrap">
 <div class="login-box">
  <div class="logo"><span class="icon icon-h_emule"></span></div>
  <h2>[eMuleAppName]</h2>
  <div class="version">[version] - [WebControl]</div>
  [FailedLogin]
  <form name="login" action="/login" method="POST">
   <div><input type="password" name="p" placeholder="Password" autofocus></div>
   <div><input type="submit" value="Login"></div>
  </form>
 </div>
</div>
</body>
</html>
<--TMPL_LOGIN_END-->


