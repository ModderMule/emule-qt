<--TMPL_HEADER_STYLESHEET-->
<style>
/* === Base === */
body {
  margin: 0; padding: 0;
  font-family: Tahoma, Verdana, Arial, sans-serif;
  font-size: 8pt;
  background: #005784;
  color: #FFFFFF;
}
a:active, a:link, a:visited { color: #FFFFFF; text-decoration: none; }
a:hover { color: #FFC412; text-decoration: none; }
form { display: inline; }
img { border: 0; }

/* === Top bar === */
.topbar {
  background: #003C6E;
  padding: 6px 12px;
  border-bottom: 1px solid #002244;
}
.topbar-left { font-size: 9pt; }
.topbar-right { font-size: 8pt; white-space: nowrap; }
.status-text { color: #99CCFF; }

/* === Navigation === */
.nav {
  background: #1F76A5;
  padding: 0 8px;
  border-bottom: 2px solid #003C6E;
}
.nav-tab {
  padding: 5px 10px;
  white-space: nowrap;
}
.nav-tab a { color: #FFFFFF; font-weight: normal; }
.nav-tab a:hover { color: #FFC412; }
.nav-tab.active {
  background: #005784;
  border-bottom: 2px solid #FFC412;
}
.nav-tab.active a { color: #FFC412; font-weight: bold; }

/* === Page content === */
.page-content { padding: 8px 12px; }

/* === Section headers === */
.section-header {
  background: #000000;
  padding: 4px 8px;
  font-weight: bold;
  font-size: 8pt;
}

/* === Table styles === */
.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 8pt;
}
.data-table th {
  background: #005784;
  padding: 3px 6px;
  text-align: center;
  font-weight: bold;
  white-space: nowrap;
}
.data-table th a { color: #FFFFFF; }
.data-table th a:hover { color: #FFC412; }
.data-table th.left { text-align: left; }
.data-table td {
  padding: 2px 6px;
  background: #1F76A5;
  border-bottom: 1px solid #005784;
  white-space: nowrap;
}
.data-table td.left { text-align: left; }
.data-table td.right { text-align: right; }
.data-table td.center { text-align: center; }

/* === Download status colors === */
.dl-downloading, .dl-downloading a { color: #00FF00; }
.dl-paused, .dl-paused a { color: #C1C1C1; }
.dl-complete, .dl-complete a { color: #1D3445; }
.dl-error, .dl-error a { color: #FF4040; }
.dl-waiting, .dl-waiting a { color: #FFFFFF; }
.dl-hashing, .dl-hashing a { color: #FFFF00; }
.dl-stalled, .dl-stalled a { color: #FFC412; }
.dl-stopped, .dl-stopped a { color: #A0A0A0; }

/* === Upload status colors === */
.ul-uploading, .ul-uploading a { color: #00FF00; }
.ul-connecting, .ul-connecting a { color: #FFFFFF; }

/* === Server status colors === */
.srv-connected, .srv-connected a { color: #00FF00; }
.srv-disconnected, .srv-disconnected a { color: #FFFFFF; }

/* === Progress bar === */
.progress-bar {
  background: #000000;
  border: 1px solid #333;
  height: 13px;
  width: 200px;
  display: inline-block;
  vertical-align: middle;
  position: relative;
}
.progress-fill {
  background: #00AA00;
  height: 100%;
  transition: width 0.3s;
}
.progress-text {
  position: absolute;
  width: 100%;
  text-align: center;
  font-size: 7pt;
  line-height: 13px;
  color: #FFFFFF;
  top: 0; left: 0;
}

/* === Shared / common panel === */
.commontext {
  background: #FFFFFF;
  color: #000000;
  font-size: 8pt;
  padding: 8px;
}
.smallheader {
  background: #003C6E;
  color: #FFFFFF;
  padding: 3px 6px;
  font-size: 8pt;
}

/* === Search form === */
.search-form {
  background: #1F76A5;
  padding: 8px;
}
.search-form td { padding: 3px 6px; font-size: 8pt; }
.search-form input[type="text"],
.search-form select {
  border: 1px dotted #000;
  padding: 2px 4px;
  font-size: 8pt;
}

/* === Preferences === */
.pref-section { background: #005784; padding: 4px 8px; font-weight: bold; }
.pref-row { background: #2184B5; padding: 4px 8px; }
.pref-row input[type="text"] {
  border: 1px dotted #000;
  padding: 2px 4px;
  font-size: 8pt;
  width: 60px;
}

/* === Log === */
.log-box {
  background: #FFFFFF;
  color: #000000;
  font-family: "Lucida Console", monospace;
  font-size: 8pt;
  padding: 8px;
  white-space: pre-wrap;
  max-height: 500px;
  overflow-y: auto;
}

/* === Footer row (table totals) === */
.data-table tfoot td {
  background: #005784;
  font-weight: bold;
  font-size: 7.5pt;
}

/* === Graphs === */
.graph-container {
  border: 1px solid green;
  height: 150px;
  background: url(stats_back.gif);
  position: relative;
}

/* === Kad === */
.kad-table {
  width: 40%;
  margin: 0 auto;
  border-collapse: collapse;
}
.kad-table td {
  background: #2184B5;
  padding: 4px 8px;
  font-size: 9pt;
}

/* === Misc === */
.message { font-weight: bold; background: #005784; padding: 4px 8px; }
</style>
<--TMPL_HEADER_STYLESHEET_END-->


