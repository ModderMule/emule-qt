#pragma once

/// @file config.h
/// @brief Platform feature detection — generated by CMake from config.h.in
///
/// Replaces the old emule_site_config.h which was Windows/MSVC-only.
/// All platform-specific feature flags are detected at configure time.

// ---------------------------------------------------------------------------
// Project version
// ---------------------------------------------------------------------------
#define EMULE_VERSION_MAJOR  @PROJECT_VERSION_MAJOR@
#define EMULE_VERSION_MINOR  @PROJECT_VERSION_MINOR@
#define EMULE_VERSION_PATCH  @PROJECT_VERSION_PATCH@
#define EMULE_VERSION_STRING "@PROJECT_VERSION@"

// ---------------------------------------------------------------------------
// Platform detection
// ---------------------------------------------------------------------------
#if defined(_WIN32) || defined(_WIN64)
    #define EMULE_OS_WINDOWS 1
#elif defined(__APPLE__) && defined(__MACH__)
    #define EMULE_OS_MACOS 1
#elif defined(__linux__)
    #define EMULE_OS_LINUX 1
#elif defined(__FreeBSD__)
    #define EMULE_OS_FREEBSD 1
#else
    #define EMULE_OS_UNKNOWN 1
#endif

#if defined(EMULE_OS_MACOS) || defined(EMULE_OS_LINUX) || defined(EMULE_OS_FREEBSD)
    #define EMULE_OS_POSIX 1
#endif

// ---------------------------------------------------------------------------
// Endianness (detected by CMake TestBigEndian)
// ---------------------------------------------------------------------------
#cmakedefine01 EMULE_BIG_ENDIAN

// ---------------------------------------------------------------------------
// System header availability (detected by CMake check_include_file_cxx)
// ---------------------------------------------------------------------------
#cmakedefine HAVE_SYS_SOCKET_H
#cmakedefine HAVE_NETINET_IN_H
#cmakedefine HAVE_ARPA_INET_H
#cmakedefine HAVE_UNISTD_H
#cmakedefine HAVE_ENDIAN_H
#cmakedefine HAVE_SYS_ENDIAN_H
#cmakedefine HAVE_EXECINFO_H

// ---------------------------------------------------------------------------
// Function availability
// ---------------------------------------------------------------------------
#cmakedefine HAVE_HTOLE32
#cmakedefine HAVE_BE64TOH

// ---------------------------------------------------------------------------
// Feature flags (replacing emule_site_config.h HAVE_* macros)
// ---------------------------------------------------------------------------
#define SUPPORT_LARGE_FILES 1